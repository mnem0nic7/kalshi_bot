APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_COLOR=blue
APP_SHADOW_MODE=true
APP_AUTO_INIT_DB=false
APP_ENABLE_KILL_SWITCH=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kalshi_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
DATABASE_URL=

LIVE_KALSHI_API_KEY=
LIVE_KALSHI_READ_PRIVATE_KEY_PATH=
LIVE_KALSHI_WRITE_PRIVATE_KEY_PATH=
DEMO_KALSHI_API_KEY=
DEMO_KALSHI_READ_PRIVATE_KEY_PATH=
DEMO_KALSHI_WRITE_PRIVATE_KEY_PATH=

LIVE_KALSHI_KEY_PATH_HOST=../Kalshi-1.txt
LIVE_KALSHI_KEY_PATH_CONTAINER=/run/secrets/kalshi-live.pem
DEMO_KALSHI_KEY_PATH_HOST=../Kalshi-2-Demo.txt
DEMO_KALSHI_KEY_PATH_CONTAINER=/run/secrets/kalshi-demo.pem

KALSHI_ENV=demo
KALSHI_READ_API_KEY_ID=
KALSHI_READ_PRIVATE_KEY_PATH=
KALSHI_WRITE_API_KEY_ID=
KALSHI_WRITE_PRIVATE_KEY_PATH=
KALSHI_SUBACCOUNT=0

WEATHER_USER_AGENT=kalshi-bot/0.1 (ops@example.com)
WEATHER_MARKET_MAP_PATH=docs/examples/weather_markets.example.yaml

LLM_HOSTED_BASE_URL=https://api.openai.com/v1
LLM_HOSTED_API_KEY=
# OPENAI_API_KEY is also accepted as an alias for LLM_HOSTED_API_KEY.
OPENAI_API_KEY=
LLM_HOSTED_MODEL=gpt-5.4
LLM_LOCAL_BASE_URL=http://localhost:11434/v1
LLM_LOCAL_API_KEY=dummy
LLM_LOCAL_MODEL=llama3.1:8b
GEMINI_API_KEY=
# GEMINI_KEY is also accepted as an alias.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_RESEARCHER=gemini-2.5-flash
GEMINI_MODEL_PRESIDENT=gemini-2.5-pro
GEMINI_MODEL_TRADER=gemini-2.5-pro
GEMINI_MODEL_RISK_OFFICER=gemini-2.5-flash
GEMINI_MODEL_OPS_MONITOR=gemini-2.5-flash
GEMINI_MODEL_MEMORY_LIBRARIAN=gemini-2.5-flash
ACTIVE_AGENT_PACK_VERSION=builtin-gemini-v1
LLM_REQUEST_TIMEOUT_SECONDS=30

RISK_MAX_ORDER_NOTIONAL_DOLLARS=50
RISK_MAX_POSITION_NOTIONAL_DOLLARS=250
RISK_DAILY_LOSS_LIMIT_DOLLARS=100
RISK_MAX_ORDER_COUNT_FP=25
RISK_STALE_MARKET_SECONDS=30
RISK_STALE_WEATHER_SECONDS=900
RISK_MIN_EDGE_BPS=50
RISK_FEE_AWARE_EDGE_ENABLED=true
RISK_MIN_PROBABILITY_EXTREMITY_PCT=25.0
RISK_PROBABILITY_MIDBAND_MAX_EXTRA_EDGE_BPS=500

MEMORY_EMBEDDING_DIMENSIONS=16
SSE_POLL_INTERVAL_SECONDS=1
RESEARCH_STALE_SECONDS=900
RESEARCH_REFRESH_COOLDOWN_SECONDS=120
RESEARCH_WEB_MAX_RESULTS=5
RESEARCH_WEB_MAX_QUERIES=2
TRAINING_WINDOW_DAYS=30
TRAINING_STATUS_ROOM_LIMIT=500
TRAINING_MIN_COMPLETE_ROOMS=25
TRAINING_MIN_MARKET_DIVERSITY=4
TRAINING_MIN_SETTLED_ROOMS=10
TRAINING_MIN_TRADE_POSITIVE_ROOMS=8
TRAINING_GOOD_RESEARCH_THRESHOLD=0.7
HISTORICAL_IMPORT_PAGE_SIZE=500
HISTORICAL_IMPORT_MAX_PAGES=25
HISTORICAL_REPLAY_MARKET_SNAPSHOT_LOOKBACK_HOURS=36
HISTORICAL_WEATHER_ARCHIVE_PATH=data/historical_weather
TRAINING_CAMPAIGN_ENABLED=false
TRAINING_CAMPAIGN_ROOMS_PER_RUN=3
TRAINING_CAMPAIGN_LOOKBACK_HOURS=24
TRAINING_CAMPAIGN_COOLDOWN_SECONDS=600
TRAINING_CAMPAIGN_MAX_RECENT_PER_MARKET=5
TRIGGER_ENABLE_AUTO_ROOMS=false
TRIGGER_COOLDOWN_SECONDS=300
TRIGGER_MAX_SPREAD_BPS=1200
TRIGGER_MAX_CONCURRENT_ROOMS=12
DAEMON_RECONCILE_INTERVAL_SECONDS=60
DAEMON_HEARTBEAT_INTERVAL_SECONDS=60
DAEMON_START_WITH_RECONCILE=true
STRATEGY_REGRESSION_DAILY_RUN_SECONDS=86400
STRATEGY_CODEX_NIGHTLY_ENABLED=true
STRATEGY_CODEX_NIGHTLY_TIMEZONE=America/Los_Angeles
STRATEGY_CODEX_NIGHTLY_HOUR_LOCAL=1
STRATEGY_AUTO_EVOLVE_ENABLED=true
STRATEGY_AUTO_EVOLVE_WINDOW_DAYS=180
STRATEGY_AUTO_EVOLVE_ACCEPT_SUGGESTIONS=true
STRATEGY_AUTO_EVOLVE_ACTIVATE_SUGGESTIONS=false
STRATEGY_AUTO_EVOLVE_ASSIGN_ELIGIBLE=false
SELF_IMPROVE_WINDOW_DAYS=14
SELF_IMPROVE_HOLDOUT_RATIO=0.2
SELF_IMPROVE_MIN_IMPROVEMENT=0.02
SELF_IMPROVE_MAX_CRITICAL_REGRESSION=0.01
SELF_IMPROVE_CANARY_MIN_ROOMS=25
SELF_IMPROVE_CANARY_MIN_SECONDS=7200
SELF_IMPROVE_LIVE_MONITOR_SECONDS=86400
SELF_IMPROVE_RESEARCH_GATE_FAILURE_THRESHOLD=0.6
SELF_IMPROVE_BLOCKED_ORDER_THRESHOLD=0.8
