APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_COLOR=blue
APP_SHADOW_MODE=true
APP_AUTO_INIT_DB=false
APP_ENABLE_KILL_SWITCH=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kalshi_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
DATABASE_URL=

LIVE_KALSHI_API_KEY=
